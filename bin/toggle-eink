#!/usr/bin/env bash
set -euo pipefail

shader="$HOME/.config/hypr/shaders/eink.glsl"

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}"
state="$state_dir/hypr-eink"

mkdir -p "$state_dir"

if [[ "$(cat "$state" 2>/dev/null || echo off)" == "on" ]]; then
	hyprctl keyword decoration:screen_shader "[[EMPTY]]"
	printf 'off\n' >"$state"
else
	hyprctl keyword decoration:screen_shader "$shader"
	printf 'on\n' >"$state"
fi
