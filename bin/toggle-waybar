#!/usr/bin/env bash
set -euo pipefail

dir="${XDG_CONFIG_HOME:-$HOME/.config}/waybar"

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}"
state="$state_dir/waybar-mode"

mkdir -p "$state_dir"

mode="$(cat "$state" 2>/dev/null || echo compact)"

case "$mode" in
compact) next=expanded ;;
*) next=compact ;;
esac

ln -sfn "$dir/$next.jsonc" "$dir/config"
printf '%s\n' "$next" >"$state"

pkill -SIGUSR2 -x waybar 2>/dev/null || true
